#!/usr/bin/env bash
# github-ship update-check — periodic version check
#
# Output (one line, or nothing):
#   JUST_UPGRADED <old> <new>
#   UPGRADE_AVAILABLE <old> <new>
#   (nothing) — up to date, snoozed, or disabled
#
# Env overrides (for testing):
#   GITHUB_SHIP_STATE_DIR  — override ~/.github-ship state directory
#   GITHUB_SHIP_REMOTE_URL — override remote VERSION URL
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="${GITHUB_SHIP_STATE_DIR:-$HOME/.github-ship}"
CACHE_FILE="$STATE_DIR/last-update-check"
MARKER_FILE="$STATE_DIR/just-upgraded-from"
SNOOZE_FILE="$STATE_DIR/update-snoozed"
VERSION_FILE="$REPO_ROOT/VERSION"
REMOTE_URL="${GITHUB_SHIP_REMOTE_URL:-https://raw.githubusercontent.com/hotsauce9000/github-ship/main/VERSION}"

# Atomic cache write: temp file + mv prevents partial reads from concurrent runs
# Note: mv atomicity is POSIX rename(2) guarantee; best-effort on Windows/NTFS
_cache_write() {
  local tmp
  tmp=$(mktemp "${CACHE_FILE}.XXXXXX") && echo "$1" > "$tmp" && mv "$tmp" "$CACHE_FILE" || { rm -f "$tmp" 2>/dev/null; return 1; }
}

# --- Force flag (busts cache + snooze for manual invocation) ---
if [ "${1:-}" = "--force" ]; then
  rm -f "$CACHE_FILE"
  rm -f "$SNOOZE_FILE"
fi

# --- Check if updates disabled ---
if [ -f "$STATE_DIR/update-check-disabled" ]; then
  exit 0
fi

# --- Read local version ---
LOCAL=""
if [ -f "$VERSION_FILE" ]; then
  LOCAL="$(cat "$VERSION_FILE" 2>/dev/null | tr -d '[:space:]')"
fi
if [ -z "$LOCAL" ]; then
  echo "github-ship: WARNING — VERSION file is empty or missing" >&2
  exit 0
fi
# Validate LOCAL is clean semver (reject pre-release like 2.1.0-beta)
if ! echo "$LOCAL" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
  echo "github-ship: WARNING — VERSION format invalid: $LOCAL" >&2
  exit 0
fi

# --- Check "just upgraded" marker ---
if [ -f "$MARKER_FILE" ]; then
  OLD="$(cat "$MARKER_FILE" 2>/dev/null | tr -d '[:space:]')"
  rm -f "$MARKER_FILE"
  rm -f "$SNOOZE_FILE"
  mkdir -p "$STATE_DIR"
  _cache_write "UP_TO_DATE $LOCAL"
  if [ -n "$OLD" ]; then
    echo "JUST_UPGRADED $OLD $LOCAL"
  fi
  exit 0
fi

# --- Snooze check helper ---
# Returns 0 if snoozed (stay quiet), 1 if not snoozed (show prompt).
# Snooze file format: <version> <level> <epoch>
# Level durations: 1=24h, 2=48h, 3+=7d
# New version (version mismatch) resets snooze.
check_snooze() {
  local remote_ver="$1"
  [ ! -f "$SNOOZE_FILE" ] && return 1
  local snoozed_ver snoozed_level snoozed_epoch
  # read puts trailing fields into last var; integer validation below catches this
  read -r snoozed_ver snoozed_level snoozed_epoch < "$SNOOZE_FILE" 2>/dev/null || return 1
  # Validate: all three fields must be non-empty
  [ -z "$snoozed_ver" ] || [ -z "$snoozed_level" ] || [ -z "$snoozed_epoch" ] && return 1
  # Validate: level and epoch must be integers
  case "$snoozed_level" in *[!0-9]*) return 1 ;; esac
  case "$snoozed_epoch" in *[!0-9]*) return 1 ;; esac
  # New version dropped? Ignore snooze.
  [ "$snoozed_ver" != "$remote_ver" ] && return 1
  # Compute snooze duration based on level
  local duration
  case "$snoozed_level" in
    1) duration=86400 ;;   # 24h
    2) duration=172800 ;;  # 48h
    *) duration=604800 ;;  # 7d (level 3+)
  esac
  local now expires
  now="$(date +%s)"
  expires=$(( snoozed_epoch + duration ))
  [ "$now" -lt "$expires" ] && return 0
  return 1
}

# --- Check cache freshness ---
# UP_TO_DATE: 60 min TTL (detect new releases quickly)
# UPGRADE_AVAILABLE: 720 min TTL (keep reminding)
if [ -f "$CACHE_FILE" ]; then
  CACHED="$(cat "$CACHE_FILE" 2>/dev/null || true)"
  case "$CACHED" in
    UP_TO_DATE*)        CACHE_TTL=60 ;;
    UPGRADE_AVAILABLE*) CACHE_TTL=720 ;;
    *)                  CACHE_TTL=0 ;;  # corrupt → force re-fetch
  esac
  STALE=$(find "$CACHE_FILE" -mmin +$CACHE_TTL 2>/dev/null || true)
  if [ -z "$STALE" ] && [ "$CACHE_TTL" -gt 0 ]; then
    case "$CACHED" in
      UP_TO_DATE*)
        CACHED_VER="$(echo "$CACHED" | awk '{print $2}')"
        [ "$CACHED_VER" = "$LOCAL" ] && exit 0
        ;;
      UPGRADE_AVAILABLE*)
        CACHED_OLD="$(echo "$CACHED" | awk '{print $2}')"
        if [ "$CACHED_OLD" = "$LOCAL" ]; then
          CACHED_NEW="$(echo "$CACHED" | awk '{print $3}')"
          check_snooze "$CACHED_NEW" && exit 0
          echo "$CACHED"
          exit 0
        fi
        ;;
    esac
  fi
fi

# --- Slow path: fetch remote version ---
mkdir -p "$STATE_DIR"
REMOTE=""
REMOTE="$(curl -sf --max-time 5 "$REMOTE_URL" 2>/dev/null || true)"
REMOTE="$(echo "$REMOTE" | tr -d '[:space:]')"

# Validate: must look like a semver version (rejects HTML, prompt injection, etc.)
if ! echo "$REMOTE" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
  _cache_write "UP_TO_DATE $LOCAL"
  exit 0
fi

if [ "$LOCAL" = "$REMOTE" ]; then
  _cache_write "UP_TO_DATE $LOCAL"
  exit 0
fi

# Semver comparison: if LOCAL >= REMOTE, treat as up-to-date (prevents downgrade)
# Portable — no sort -V (unavailable on older macOS BSD sort)
_ver_gte() {
  local IFS=.
  local -a a=($1) b=($2)
  for i in 0 1 2; do
    [ "${a[i]:-0}" -gt "${b[i]:-0}" ] && return 0
    [ "${a[i]:-0}" -lt "${b[i]:-0}" ] && return 1
  done
  return 0  # equal
}
if _ver_gte "$LOCAL" "$REMOTE"; then
  _cache_write "UP_TO_DATE $LOCAL"
  exit 0
fi

# Upgrade available (REMOTE is strictly newer)
_cache_write "UPGRADE_AVAILABLE $LOCAL $REMOTE"
check_snooze "$REMOTE" && exit 0
echo "UPGRADE_AVAILABLE $LOCAL $REMOTE"
