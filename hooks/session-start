#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SHIP_SKILL_MD="${PLUGIN_ROOT}/skills/github-ship/SKILL.md"
PR_SKILL_MD="${PLUGIN_ROOT}/skills/github-pr/SKILL.md"
SAVE_SKILL_MD="${PLUGIN_ROOT}/skills/save/SKILL.md"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Read description from SKILL.md YAML frontmatter
read_description() {
    local skill_md="$1"
    local desc=""
    if [ -f "$skill_md" ]; then
        local in_frontmatter=false
        while IFS= read -r line; do
            line="${line%$'\r'}"
            if [[ "$line" == "---" ]]; then
                if $in_frontmatter; then break; fi
                in_frontmatter=true
                continue
            fi
            if $in_frontmatter && [[ "$line" == description:* ]]; then
                desc="${line#description: }"
            fi
        done < "$skill_md"
    fi
    printf '%s' "$desc"
}

ship_desc=$(read_description "$SHIP_SKILL_MD")
pr_desc=$(read_description "$PR_SKILL_MD")
save_desc=$(read_description "$SAVE_SKILL_MD")

if [ -z "$ship_desc" ]; then
    echo "github-ship: WARNING — could not read description from ${SHIP_SKILL_MD}" >&2
    ship_desc="Invoke /github-ship when the user wants to ship, commit, tag, and release code."
fi
if [ -z "$pr_desc" ]; then
    echo "github-ship: WARNING — could not read description from ${PR_SKILL_MD}" >&2
    pr_desc="Invoke /github-pr when the user wants to open a pull request for team review."
fi
if [ -z "$save_desc" ]; then
    echo "github-ship: WARNING — could not read description from ${SAVE_SKILL_MD}" >&2
    save_desc="Invoke /save for a quick commit and push without the full ceremony."
fi

session_context="You have three shipping skills available: /save (quick commit+push), /github-pr (team PRs), and /github-ship (solo releases). ${save_desc} ${pr_desc} ${ship_desc}"
escaped=$(escape_for_json "$session_context")

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
fi

exit 0
